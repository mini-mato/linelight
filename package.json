{
  "name": "linelight",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "A digital benchtop for atomic physics — synced instrument suite.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && pnpm build:atlas && pnpm build:atlas-db",
    "build:atlas": "node --import tsx tools/build-atlas-thumbnails.ts",
    "build:atlas-app": "node --import tsx tools/build-atlas-app.ts",
    "build:atlas-db": "node --import tsx tools/build-atlas-db.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "three": "^0.171.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.10.0",
    "@types/three": "^0.171.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  },
  "packageManager": "pnpm@9.15.0"
}
