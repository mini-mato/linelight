    {
      "id": "polytope.regular.2d.n-gon",
      "family": "polytope",
      "name": "regular n-gon",
      "symbol": "{n}",
      "attrs": {
        "dimension": 2,
        "schlafli": ["n"],
        "formulas": {
          "interior_angle": {
            "latex": "\\theta = \\pi (n-2) / n",
            "closedForm": "(n-2)*pi/n",
            "reference": "Coxeter 1973 §1.5"
          },
          "circumradius": {
            "latex": "R = a / (2 \\sin(\\pi/n))",
            "closedForm": "a/(2*sin(pi/n))",
            "reference": "Coxeter 1973 §1.5"
          },
          "area": {
            "latex": "A = (n a^2 / 4) \\cot(\\pi/n)",
            "closedForm": "n*a^2*cot(pi/n)/4",
            "reference": "Coxeter 1973 §1.5"
          }
        }
      },
      "sourceId": "coxeter-1973",
      "retrievedAt": "2026-05-04",
      "notes": "Parametric family. Limit n -> infinity yields a circle."
    },
