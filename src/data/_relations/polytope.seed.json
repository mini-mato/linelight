    {
      "id": "polytope.regular.nd.n-simplex",
      "family": "polytope",
      "name": "n-simplex",
      "symbol": "{3^(n-1)}",
      "attrs": {
        "dimension": "n",
        "schlafli": [3, "n"],
        "formulas": {
          "k_face_count": {
            "latex": "f_k = \\binom{n+1}{k+1}",
            "closedForm": "C(n+1, k+1)",
            "reference": "Coxeter 1973 §7.2"
          },
          "volume_unit_edge": {
            "latex": "V = \\sqrt{n+1} / (n! \\cdot 2^{n/2})",
            "closedForm": "sqrt(n+1)/(n! * 2^(n/2))",
            "reference": "Coxeter 1973 §7.2"
          },
          "circumradius": {
            "latex": "R = \\sqrt{n / (2(n+1))}",
            "closedForm": "sqrt(n/(2*(n+1)))",
            "reference": "Coxeter 1973 §7.2"
          }
        }
      },
      "sourceId": "coxeter-1973",
      "retrievedAt": "2026-05-04",
      "notes": "Self-dual in every dimension. n+1 vertices."
    },
